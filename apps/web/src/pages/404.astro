---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404 - Page Not Found | Bun Starter">
  <div class="flex min-h-[60vh] flex-col items-center justify-center px-4">
    <div class="text-center">
      <p class="text-8xl font-bold text-primary-200">404</p>
      <h1 class="mt-4 text-3xl font-bold tracking-tight text-gray-900">
        Page not found
      </h1>
      <p class="mt-4 text-lg text-gray-600">
        Sorry, we couldn't find the page you're looking for.
      </p>
      <div class="mt-8 flex gap-4 justify-center">
        <a
          href="/"
          class="rounded-md bg-primary-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-primary-500"
        >
          Go home
        </a>
        <a
          href="/dashboard"
          class="rounded-md bg-gray-100 px-4 py-2.5 text-sm font-semibold text-gray-700 hover:bg-gray-200"
        >
          View dashboard
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
