---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Home | Bun Starter">
  <section class="relative overflow-hidden py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1 class="text-5xl font-bold tracking-tight text-gray-900 sm:text-6xl">
          TypeScript Bun Starter
        </h1>
        <p class="mt-6 text-lg leading-8 text-gray-600 max-w-2xl mx-auto">
          A modern, type-safe foundation for your next project. CLI, API, and WebApp
          tiers ready to go.
        </p>
        <div class="mt-10 flex items-center justify-center gap-x-6">
          <a
            href="/dashboard"
            class="rounded-md bg-primary-600 px-3.5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-primary-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-600"
          >
            Get Started
          </a>
          <a
            href="https://bun.sh"
            class="text-sm font-semibold leading-6 text-gray-900 flex items-center gap-1"
          >
            Learn about Bun
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="py-24 bg-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-center mb-16">Features</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="p-6 rounded-xl border border-gray-200 hover:border-primary-300 transition-colors">
          <div class="w-12 h-12 rounded-lg bg-primary-100 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold mb-2">Lightning Fast</h3>
          <p class="text-gray-600">
            Built on Bun runtime for optimal performance. Start developing in seconds.
          </p>
        </div>

        <div class="p-6 rounded-xl border border-gray-200 hover:border-primary-300 transition-colors">
          <div class="w-12 h-12 rounded-lg bg-primary-100 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold mb-2">TypeScript Native</h3>
          <p class="text-gray-600">
            Full type safety out of the box. Strict mode enabled by default.
          </p>
        </div>

        <div class="p-6 rounded-xl border border-gray-200 hover:border-primary-300 transition-colors">
          <div class="w-12 h-12 rounded-lg bg-primary-100 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
            </svg>
          </div>
          <h3 class="text-lg font-semibold mb-2">Modern Stack</h3>
          <p class="text-gray-600">
            Astro 5 SSG, React islands, Tailwind CSS v4, Hono API server.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold mb-4">Ready to Build?</h2>
      <p class="text-gray-600 mb-8">
        Check out the dashboard to see interactive React components in action.
      </p>
      <a
        href="/dashboard"
        class="inline-flex items-center gap-2 rounded-md border border-transparent bg-primary-600 px-6 py-3 text-base font-medium text-white hover:bg-primary-500"
      >
        View Dashboard
        <span>→</span>
      </a>
    </div>
  </section>
</BaseLayout>
