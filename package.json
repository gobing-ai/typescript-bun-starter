{
    "name": "@gobing-ai/typescript-bun-starter",
    "version": "0.2.0",
    "description": "Bun-first monorepo starter and scaffold CLI for building CLI, CLI+API, or CLI+API+Web projects with strict TypeScript, shared contracts, and a generated-project workflow exercised in CI.",
    "keywords": [
        "bun",
        "typescript",
        "monorepo",
        "starter",
        "scaffold",
        "cli",
        "hono",
        "astro",
        "drizzle",
        "biome"
    ],
    "homepage": "https://github.com/gobing-ai/typescript-bun-starter",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/gobing-ai/typescript-bun-starter.git"
    },
    "bugs": {
        "url": "https://github.com/gobing-ai/typescript-bun-starter/issues"
    },
    "license": "MIT",
    "author": "Robin Min <minlongbing@gmail.com>",
    "type": "module",
    "engines": {
        "bun": ">=1.3.0"
    },
    "files": [
        "apps",
        "packages",
        "scripts",
        "contracts",
        "drizzle",
        "AGENTS.md",
        "CLAUDE.md",
        "GEMINI.md",
        "LICENSE",
        "README.md",
        "tsconfig.json",
        "biome.json"
    ],
    "publishConfig": {
        "access": "public"
    },
    "workspaces": [
        "packages/*",
        "apps/*"
    ],
    "scripts": {
        "scaffold:init": "bun run apps/cli/src/index.ts scaffold init",
        "scaffold:add": "bun run apps/cli/src/index.ts scaffold add",
        "scaffold:remove": "bun run apps/cli/src/index.ts scaffold remove",
        "scaffold:validate": "bun run apps/cli/src/index.ts scaffold validate",
        "scaffold:list": "bun run apps/cli/src/index.ts scaffold list",
        "bootstrap": "bun run apps/cli/src/index.ts scaffold init",
        "clean-demo": "bun run apps/cli/src/index.ts scaffold remove skills",
        "check": "biome check . --error-on-warnings && bun run scaffold:validate && bun run check:docs && bun run check:policy && bun run typecheck && bun run test:coverage",
        "check:contracts": "bun run scaffold:validate",
        "check:docs": "bun run scripts/check-docs.ts",
        "check:instructions": "bun run scaffold:validate",
        "generate:instructions": "bun run scripts/generate-instructions.ts",
        "check:policy": "bun run scripts/policy-check.ts",
        "smoke:generated": "bun run scripts/smoke-generated-project.ts",
        "test": "bun test --coverage --coverage-reporter=lcov --coverage-dir=coverage && bun run scripts/check-coverage.ts",
        "test:coverage": "bun test --coverage --coverage-reporter=text --coverage-reporter=lcov --coverage-dir=coverage --reporter=dots && bun run scripts/check-coverage.ts",
        "format": "biome format --write .",
        "lint-fix": "biome lint --write .",
        "autofix": "bun run format && bun run lint-fix",
        "autofix2": "bun run autofix && bun run scripts/policy-check.ts --fix",
        "typecheck": "tsc --noEmit",
        "db:push": "drizzle-kit push",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "dev:cli": "bun run --filter @starter/cli dev",
        "dev:server": "bun run --filter @starter/server dev",
        "dev:web": "bun run --filter @starter/web dev",
        "dev:all": "bun run scripts/dev-all.ts",
        "dev:observability": "docker compose -f dockers/docker-compose.observability.yml up -d",
        "dev:observability:down": "docker compose -f dockers/docker-compose.observability.yml down",
        "dev:observability:logs": "docker compose -f dockers/docker-compose.observability.yml logs -f",
        "build:web": "bun run --filter @starter/web build",
        "build:cli": "bun build --compile apps/cli/src/index.ts --outfile dist/tbs",
        "tree": "tree . -a -I 'node_modules|.git|coverage'",
        "pub2npmjs": "npm whoami >/dev/null 2>&1 || { echo 'Error: not logged in to npm. Run `npm login` first.'; exit 1; } && npm publish --access public"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.13",
        "@logtape/logtape": "2.0.5",
        "@opentelemetry/sdk-trace-base": "2.7.0",
        "@types/bun": "1.3.13",
        "better-sqlite3": "12.9.0",
        "drizzle-kit": "0.31.10",
        "typescript": "6.0.3"
    }
}
