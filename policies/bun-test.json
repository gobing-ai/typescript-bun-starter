{
    "id": "bun-test",
    "description": "Enforces using Bun test instead of Vitest",
    "rationale": [
        "Bun test is faster and built-in",
        "Avoids external dependency",
        "Consistent testing with Bun runtime"
    ],
    "notes": [
        "These fixes are intentionally first-pass migrations for existing projects.",
        "They can introduce compile errors or semantic gaps that need manual cleanup after the mechanical rewrite."
    ],
    "targets": ["apps/**/*.ts", "packages/**/*.ts", "scripts/**/*.ts"],
    "rules": [
        {
            "id": "no-vitest-import",
            "engine": "rg",
            "message": "Use bun:test instead of vitest",
            "severity": "error",
            "match": {
                "kind": "rg",
                "pattern": "from ['\"]vitest['\"]"
            },
            "fix": {
                "mode": "rewrite",
                "replace": "from 'bun:test'"
            }
        },
        {
            "id": "no-vi.fn",
            "engine": "rg",
            "message": "vi.fn() is vitest-specific",
            "severity": "error",
            "match": {
                "kind": "rg",
                "pattern": "vi\\.fn\\("
            },
            "fix": {
                "mode": "rewrite",
                "replace": "bun.fn("
            }
        },
        {
            "id": "no-vi.spyOn",
            "engine": "rg",
            "message": "vi.spyOn is vitest-specific",
            "severity": "error",
            "match": {
                "kind": "rg",
                "pattern": "vi\\.spyOn"
            },
            "fix": {
                "mode": "rewrite",
                "replace": "bun.spyOn"
            }
        },
        {
            "id": "no-vi.mock",
            "engine": "rg",
            "message": "vi.mock is vitest-specific",
            "severity": "error",
            "match": {
                "kind": "rg",
                "pattern": "vi\\.mock"
            },
            "fix": {
                "mode": "rewrite",
                "replace": "bun.mock"
            }
        },
        {
            "id": "no-vi.stub",
            "engine": "rg",
            "message": "vi.stub is vitest-specific",
            "severity": "error",
            "match": {
                "kind": "rg",
                "pattern": "vi\\.stub"
            },
            "fix": {
                "mode": "rewrite",
                "replace": "bun.stub"
            }
        },
        {
            "id": "no-vitest-config",
            "engine": "rg",
            "message": "vitest.config.ts should be removed",
            "severity": "error",
            "match": {
                "kind": "rg",
                "pattern": "vitest\\.config"
            }
        }
    ]
}
