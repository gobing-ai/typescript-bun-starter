{
    "id": "logger",
    "description": "Enforces using @logtape/logtape logger instead of console.*",
    "rationale": [
        "Consistent structured logging across the codebase",
        "Logger supports log levels, sinks, and formatting",
        "console.* bypasses the logging infrastructure"
    ],
    "notes": [
        "These fixes are intentionally first-pass migrations for existing projects.",
        "They may leave compile errors behind because imports and API semantics can still need manual follow-up."
    ],
    "targets": ["apps/**/*.ts", "packages/**/*.ts"],
    "rules": [
        {
            "id": "no-console-log",
            "engine": "rg",
            "message": "Use logger.* instead of console.log",
            "severity": "error",
            "allow": ["scripts/policy-check.ts"],
            "match": {
                "kind": "rg",
                "pattern": "console\\.log"
            },
            "fix": {
                "mode": "rewrite",
                "replace": "logger.log"
            }
        },
        {
            "id": "no-console-error",
            "engine": "rg",
            "message": "Use logger.error instead of console.error",
            "severity": "error",
            "allow": ["scripts/policy-check.ts"],
            "match": {
                "kind": "rg",
                "pattern": "console\\.error"
            },
            "fix": {
                "mode": "rewrite",
                "replace": "logger.error"
            }
        },
        {
            "id": "no-console-warn",
            "engine": "rg",
            "message": "Use logger.warn instead of console.warn",
            "severity": "warning",
            "allow": ["scripts/policy-check.ts"],
            "match": {
                "kind": "rg",
                "pattern": "console\\.warn"
            },
            "fix": {
                "mode": "rewrite",
                "replace": "logger.warn"
            }
        },
        {
            "id": "no-console-debug",
            "engine": "rg",
            "message": "Use logger.debug instead of console.debug",
            "severity": "warning",
            "allow": ["scripts/policy-check.ts"],
            "match": {
                "kind": "rg",
                "pattern": "console\\.debug"
            },
            "fix": {
                "mode": "rewrite",
                "replace": "logger.debug"
            }
        },
        {
            "id": "no-console-info",
            "engine": "rg",
            "message": "Use logger.info instead of console.info",
            "severity": "warning",
            "allow": ["scripts/policy-check.ts"],
            "match": {
                "kind": "rg",
                "pattern": "console\\.info"
            },
            "fix": {
                "mode": "rewrite",
                "replace": "logger.info"
            }
        },
        {
            "id": "no-console-dir",
            "engine": "rg",
            "message": "Use logger.debug with object instead of console.dir",
            "severity": "warning",
            "allow": ["scripts/policy-check.ts"],
            "match": {
                "kind": "rg",
                "pattern": "console\\.dir"
            },
            "fix": {
                "mode": "rewrite",
                "replace": "logger.debug"
            }
        },
        {
            "id": "no-console-time",
            "engine": "rg",
            "message": "Use logger with timing metadata instead of console.time",
            "severity": "warning",
            "allow": ["scripts/policy-check.ts"],
            "match": {
                "kind": "rg",
                "pattern": "console\\.time"
            },
            "fix": {
                "mode": "rewrite",
                "replace": "logger.debug"
            }
        },
        {
            "id": "no-console-trace",
            "engine": "rg",
            "message": "Use logger.debug with stack trace instead of console.trace",
            "severity": "warning",
            "allow": ["scripts/policy-check.ts"],
            "match": {
                "kind": "rg",
                "pattern": "console\\.trace"
            },
            "fix": {
                "mode": "rewrite",
                "replace": "logger.debug"
            }
        }
    ]
}
