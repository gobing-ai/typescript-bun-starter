{
    "id": "no-secrets",
    "description": "Detects hardcoded secrets and sensitive data",
    "rationale": ["Prevent accidental secret exposure", "Security best practice"],
    "targets": ["apps/**/*.ts", "packages/**/*.ts"],
    "exclude": ["**/*.test.ts", "**/node_modules/**", "**/dist/**"],
    "rules": [
        {
            "id": "no-api-key-hardcoded",
            "engine": "rg",
            "message": "Hardcoded API key detected",
            "severity": "error",
            "match": {
                "kind": "rg",
                "pattern": "(?i)(api[_-]?key|apikey|api_secret|access[_-]?token|auth[_-]?token|secret[_-]key)[\\s]*[=:]"
            }
        },
        {
            "id": "no-private-key-hardcoded",
            "engine": "rg",
            "message": "Hardcoded private key detected",
            "severity": "error",
            "match": {
                "kind": "rg",
                "pattern": "PRIVATE[_-]?KEY|----BEGIN\\s+[A-Z]+\\s+PRIVATE"
            }
        },
        {
            "id": "no-password-hardcoded",
            "engine": "rg",
            "message": "Hardcoded password detected",
            "severity": "error",
            "match": {
                "kind": "rg",
                "pattern": "(?i)(password|passwd|pwd|pass)[\\s]*[=:]"
            }
        }
    ]
}
