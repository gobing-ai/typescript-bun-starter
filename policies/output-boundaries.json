{
    "id": "output-boundaries",
    "description": "Enforces plain-output boundaries by preventing direct stdout/stderr writes outside approved exceptions.",
    "rationale": [
        "Human-facing plain output should flow through echo/echoError for consistency and testability.",
        "Direct stdout/stderr writes should be limited to explicit passthrough and JSON serialization exceptions."
    ],
    "notes": [
        "Allow lists cover the intentional exceptions discussed during implementation.",
        "JSON serialization and raw subprocess passthrough stay explicit at their call sites."
    ],
    "targets": ["apps/**/*.ts", "packages/**/*.ts", "scripts/**/*.ts"],
    "exclude": ["**/tests/**", "**/node_modules/**", "**/dist/**"],
    "rules": [
        {
            "id": "no-process-stdout-write",
            "engine": "rg",
            "message": "Use echo(...) instead of process.stdout.write(...)",
            "severity": "error",
            "allow": ["scripts/smoke-generated-project.ts", "scripts/policy-check.ts"],
            "match": {
                "kind": "rg",
                "pattern": "process\\.stdout\\.write\\("
            }
        },
        {
            "id": "no-process-stderr-write",
            "engine": "rg",
            "message": "Use echoError(...) instead of process.stderr.write(...)",
            "severity": "error",
            "allow": ["scripts/smoke-generated-project.ts"],
            "match": {
                "kind": "rg",
                "pattern": "process\\.stderr\\.write\\("
            }
        },
        {
            "id": "no-context-stdout-write",
            "engine": "rg",
            "message": "Use echo(...) instead of direct text-mode context.stdout.write(...)",
            "severity": "error",
            "allow": ["apps/cli/src/commands/scaffold/base-scaffold-command.ts"],
            "match": {
                "kind": "rg",
                "pattern": "context\\.stdout\\.write\\("
            }
        },
        {
            "id": "no-context-stderr-write",
            "engine": "rg",
            "message": "Use echoError(...) instead of direct text-mode context.stderr.write(...)",
            "severity": "error",
            "allow": ["apps/cli/src/commands/scaffold/base-scaffold-command.ts"],
            "match": {
                "kind": "rg",
                "pattern": "context\\.stderr\\.write\\("
            }
        }
    ]
}
